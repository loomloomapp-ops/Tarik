# TARIK Invest — Apache config
AddDefaultCharset UTF-8
Options -Indexes
DirectoryIndex index.php index.html

# Force UTF-8 for text
<IfModule mod_headers.c>
  <FilesMatch "\.(html|php|css|js)$">
    Header set Content-Type "text/html; charset=UTF-8" env=is_html
  </FilesMatch>
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Protect internal folders
RedirectMatch 403 ^/lib/.*\.(json|php)$
RedirectMatch 403 ^/uploads/.*$
