# TARIK Invest — static Next.js build on Apache (no Node)
AddDefaultCharset UTF-8
Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# Form endpoints -> PHP handler (Next client posts JSON here)
RewriteRule ^api/lead/?$ api/submit.php [L]
RewriteRule ^api/career/?$ api/submit.php [L]

# Protect the fallback submission log
RewriteRule ^api/_log(/.*)?$ - [F]

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType text/css "access plus 365 days"
  ExpiresByType application/javascript "access plus 365 days"
  ExpiresByType font/woff2 "access plus 365 days"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Long cache for immutable hashed Next assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
